---
import Base from '../layouts/Base.astro';

const photos = [
  { src: '/photos/Glimpse.jpg', alt: 'Glimpse' },
  { src: '/photos/Isolated.jpg', alt: 'Isolated' },
  { src: '/photos/Kill-With-A-Smile.jpg', alt: 'Kill With A Smile' },
  { src: '/photos/A-Story-My-Father-Told-Me.jpg', alt: 'A Story My Father Told Me' },
  { src: '/photos/Scale.jpg', alt: 'Scale' },
  { src: '/photos/Not-So-Blue.jpg', alt: 'Not So Blue' },
  { src: '/photos/Procession.jpg', alt: 'Procession' },
  { src: '/photos/Light-the-Way.jpg', alt: 'Light the Way' },
  { src: '/photos/Live-Die-Live-Again.png', alt: 'Live Die Live Again' },
  { src: '/photos/Tolt.jpg', alt: 'Tölt' },
  { src: '/photos/Pass-the-Salt.jpg', alt: 'Pass the Salt' },
  { src: '/photos/Happy-Neigh-Year.jpg', alt: 'Happy Neigh Year' },
  { src: '/photos/Two-Birds.png', alt: 'Two Birds' },
  { src: '/photos/My-Light.jpg', alt: 'My Light' },
  { src: '/photos/Steering-Contest.jpg', alt: 'Steering Contest' },
  { src: '/photos/No-Nagging.jpg', alt: 'No Nagging' },
  { src: '/photos/Swoop.jpg', alt: 'Swoop' },
  { src: '/photos/Twinning.jpg', alt: 'Twinning' },
];
---

<Base
  title="Pierce Liefeld — Photographer & Founder of COGNAK"
  description="Photography by Pierce Liefeld. Design director and founder of COGNAK."
>
  <!-- Person + Organization schema -->
  <script type="application/ld+json" is:inline>{JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://pierceliefeld.com/#pierce",
        "name": "Pierce Liefeld",
        "url": "https://pierceliefeld.com",
        "image": "https://pierceliefeld.com/photos/Glimpse.jpg",
        "jobTitle": "Design Director",
        "description": "Design director, photographer, and founder of COGNAK.",
        "sameAs": ["https://cognak.com"],
        "worksFor": {
          "@type": "Organization",
          "@id": "https://cognak.com/#organization"
        }
      },
      {
        "@type": "Organization",
        "@id": "https://cognak.com/#organization",
        "name": "COGNAK",
        "url": "https://cognak.com",
        "founder": { "@id": "https://pierceliefeld.com/#pierce" }
      }
    ]
  })}</script>

  <main>
    <header>
      <div class="bio reveal">
        <h1>Pierce Liefeld</h1>
        <p>
          Design director. Photographer. Founder of&nbsp;<a href="https://cognak.com" target="_blank" rel="noopener">COGNAK</a>.
        </p>
      </div>
    </header>

    <section class="grid" id="grid">
      {photos.map((photo, i) => (
        <div
          class="photo-item reveal"
          style={`transition-delay: ${Math.min(i * 40, 200)}ms`}
        >
          <div class="photo-ring">
            <svg class="ring-svg" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="18" cy="18" r="16" stroke="#9F50FF" stroke-width="2" stroke-linecap="round"
                stroke-dasharray="100.53" stroke-dashoffset="100.53" class="ring-track"/>
            </svg>
          </div>
          <img
            src={photo.src}
            alt={photo.alt}
            loading={i < 6 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ))}
    </section>

    <footer>
      <span>© 2026 Pierce Liefeld</span>
    </footer>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var grid = document.getElementById('grid');
      var items = Array.from(grid.querySelectorAll('.photo-item'));
      var HOLD_MS = 600;

      items.forEach(function (item) {
        var timer = null;
        var ring = item.querySelector('.ring-track');
        var anim = null;

        function startHold() {
          // Animate ring drawing over HOLD_MS
          var start = null;
          var circumference = 100.53;
          ring.style.transition = 'none';
          ring.style.strokeDashoffset = circumference;
          ring.style.opacity = '1';

          function step(ts) {
            if (!start) start = ts;
            var progress = Math.min((ts - start) / HOLD_MS, 1);
            ring.style.strokeDashoffset = circumference * (1 - progress);
            if (progress < 1) {
              anim = requestAnimationFrame(step);
            } else {
              // Ring complete — expand this item, dim others
              grid.classList.add('has-focus');
              item.classList.add('focused');
              ring.style.opacity = '0';
              ring.style.transition = 'opacity 0.3s ease';
            }
          }
          anim = requestAnimationFrame(step);

          timer = null;
        }

        function cancelHold() {
          if (anim) { cancelAnimationFrame(anim); anim = null; }
          if (timer) { clearTimeout(timer); timer = null; }
          ring.style.transition = 'opacity 0.2s ease, stroke-dashoffset 0.2s ease';
          ring.style.strokeDashoffset = '100.53';
          ring.style.opacity = '0';
          grid.classList.remove('has-focus');
          item.classList.remove('focused');
        }

        item.addEventListener('mouseenter', function () {
          timer = setTimeout(startHold, 0); // start immediately, ring animates over HOLD_MS
        });

        item.addEventListener('mouseleave', cancelHold);
      });
    });
  </script>
</Base>

<style>
  main {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  header {
    padding: 3rem 2rem 2rem;
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
  }

  .bio h1 {
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--fg);
    margin-bottom: 0.35rem;
  }

  .bio p {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .bio a {
    color: var(--accent);
    font-weight: 700;
    transition: color 0.2s ease;
  }

  .bio a:hover {
    color: #9F50FF;
  }

  /* Masonry via CSS columns */
  .grid {
    column-count: 3;
    column-gap: var(--gap);
    padding: 0 var(--gap) var(--gap);
    flex: 1;
  }

  .photo-item {
    break-inside: avoid;
    margin-bottom: var(--gap);
    overflow: hidden;
    border-radius: var(--radius);
    background: #1a1820;
    position: relative;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s ease,
                z-index 0s;
  }

  /* Ring overlay */
  .photo-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    z-index: 10;
    pointer-events: none;
  }

  .ring-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .ring-track {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  /* Focused state */
  .photo-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.35s ease, transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0.9;
  }

  /* When grid has a focused item, dim all others */
  .grid.has-focus .photo-item {
    opacity: 0.15;
    transition: opacity 0.45s ease, transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .grid.has-focus .photo-item.focused {
    opacity: 1;
    transform: scale(1.3);
    z-index: 2;
    position: relative;
  }

  .grid.has-focus .photo-item.focused img {
    opacity: 1;
  }

  footer {
    padding: 1.5rem 2rem;
    font-size: 0.75rem;
    color: var(--fg-muted);
    font-weight: 400;
    letter-spacing: 0.02em;
    font-family: var(--font-mono);
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .grid {
      column-count: 2;
    }
    header {
      padding: 2rem 1.25rem 1.5rem;
    }
  }

  @media (max-width: 540px) {
    .grid {
      column-count: 1;
      padding: 0 0.5rem 0.5rem;
    }
    header {
      padding: 1.5rem 1rem 1rem;
    }
    .bio h1 {
      font-size: 1rem;
    }
  }
</style>
