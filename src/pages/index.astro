---
import Base from '../layouts/Base.astro';

const photos = [
  { src: '/photos/Glimpse.jpg', alt: 'Glimpse' },
  { src: '/photos/Isolated.jpg', alt: 'Isolated' },
  { src: '/photos/Kill-With-A-Smile.jpg', alt: 'Kill With A Smile' },
  { src: '/photos/A-Story-My-Father-Told-Me.jpg', alt: 'A Story My Father Told Me' },
  { src: '/photos/Scale.jpg', alt: 'Scale' },
  { src: '/photos/Not-So-Blue.jpg', alt: 'Not So Blue' },
  { src: '/photos/Procession.jpg', alt: 'Procession' },
  { src: '/photos/Light-the-Way.jpg', alt: 'Light the Way' },
  { src: '/photos/Live-Die-Live-Again.jpg', alt: 'Live Die Live Again' },
  { src: '/photos/Tolt.jpg', alt: 'Tölt' },
  { src: '/photos/Pass-the-Salt.jpg', alt: 'Pass the Salt' },
  { src: '/photos/Happy-Neigh-Year.jpg', alt: 'Happy Neigh Year' },
  { src: '/photos/Two-Birds.jpg', alt: 'Two Birds' },
  { src: '/photos/My-Light.jpg', alt: 'My Light' },
  { src: '/photos/Steering-Contest.jpg', alt: 'Steering Contest' },
  { src: '/photos/No-Nagging.jpg', alt: 'No Nagging' },
  { src: '/photos/Swoop.jpg', alt: 'Swoop' },
  { src: '/photos/Twinning.jpg', alt: 'Twinning' },
];
---

<Base
  title="Pierce Liefeld — Photographer & Founder of COGNAK"
  description="Photography by Pierce Liefeld. Design director and founder of COGNAK."
>
  <!-- Person + Organization schema -->
  <script type="application/ld+json" is:inline>{JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://pierceliefeld.com/#pierce",
        "name": "Pierce Liefeld",
        "url": "https://pierceliefeld.com",
        "image": "https://pierceliefeld.com/photos/Glimpse.jpg",
        "jobTitle": "Design Director",
        "description": "Design director, photographer, and founder of COGNAK.",
        "sameAs": ["https://cognak.com"],
        "worksFor": {
          "@type": "Organization",
          "@id": "https://cognak.com/#organization"
        }
      },
      {
        "@type": "Organization",
        "@id": "https://cognak.com/#organization",
        "name": "COGNAK",
        "url": "https://cognak.com",
        "founder": { "@id": "https://pierceliefeld.com/#pierce" }
      }
    ]
  })}</script>

  <main>
    <header>
      <div class="bio reveal">
        <h1>Pierce Liefeld</h1>
        <p>
          Design director. Photographer. Founder of&nbsp;<span class="cognak-wrap">
            <a href="https://cognak.com" target="_blank" rel="noopener" id="cognak-link">COGNAK</a>
            <span class="cognak-preview" id="cognak-preview">
              <iframe src="https://cognak.com" scrolling="no" tabindex="-1" loading="lazy" title="COGNAK"></iframe>
            </span>
          </span>.
        </p>
      </div>
    </header>

    <section class="grid">
      {photos.map((photo, i) => (
        <div class="photo-item reveal" style={`transition-delay: ${Math.min(i * 40, 200)}ms`}>
          <img
            src={photo.src}
            alt={photo.alt}
            loading={i < 6 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ))}
    </section>

    <footer>
      <span>© 2026 Pierce Liefeld</span>
    </footer>
  </main>

  <!-- Randomize photo order on every page load -->
  <script is:inline>
    (function () {
      var grid = document.querySelector('.grid');
      if (!grid) return;
      var items = Array.prototype.slice.call(grid.children);
      for (var i = items.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = items[i]; items[i] = items[j]; items[j] = t;
      }
      items.forEach(function (el, idx) {
        el.style.transitionDelay = Math.min(idx * 40, 200) + 'ms';
        grid.appendChild(el);
      });
    })();
  </script>
</Base>

<style>
  main {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  header {
    padding: 3rem 2rem 2rem;
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .bio h1 {
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--fg);
    margin-bottom: 0.35rem;
  }

  .bio p {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  /* COGNAK link + preview card */
  .cognak-wrap {
    position: relative;
    display: inline-block;
  }

  .bio a,
  .bio a:hover,
  .bio a:active,
  .bio a:focus {
    color: #9F50FF;
    font-weight: 700;
    transition: color 0.2s ease;
  }

  .cognak-preview {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    width: 384px;
    height: 216px; /* 16:9 hero ratio */
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(159,80,255,0.25);
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 100;
  }

  .cognak-wrap:hover .cognak-preview {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .cognak-preview iframe {
    width: 1536px;
    height: 864px; /* 16:9 of 1536 */
    transform: scale(0.25);
    transform-origin: top left;
    border: none;
    pointer-events: none;
  }

  /* Masonry */
  .grid {
    column-count: 3;
    column-gap: var(--gap);
    padding: 0 var(--gap) var(--gap);
    flex: 1;
  }

  .photo-item {
    break-inside: avoid;
    margin-bottom: var(--gap);
    overflow: hidden;
    border-radius: var(--radius);
    background: #1a1820;
  }

  .photo-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease, transform 0.4s ease;
    opacity: 0.92;
  }

  .photo-item:hover img {
    opacity: 1;
    transform: scale(1.012);
  }

  footer {
    padding: 1.5rem 2rem;
    font-size: 0.75rem;
    color: var(--fg-muted);
    font-weight: 400;
    letter-spacing: 0.02em;
    font-family: var(--font-mono);
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .grid { column-count: 2; }
    header { padding: 2rem 1.25rem 1.5rem; }
    .cognak-preview { width: 304px; height: 171px; }
    .cognak-preview iframe { width: 1216px; height: 684px; transform: scale(0.25); }
  }

  @media (max-width: 540px) {
    .grid { column-count: 1; padding: 0 0.5rem 0.5rem; }
    header { padding: 100px 1rem 1rem; }
    .cognak-preview { display: none; }
  }
</style>
